{
  "expo": {
    "name": "Smart Notes",
    "slug": "smart-notes",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/images/appicon.png",

    "scheme": "smartnotes",
    "userInterfaceStyle": "automatic",

    "ios": {
      "icon": "./assets/images/appicon.png"
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/appicon.png",
        "backgroundColor": "#6C63FF"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.faizan4dev.smartnotes"
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/appicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fa4a62f7-cacf-41b5-b609-cf1d7485fb45"
      }
    }
  }
}
